print("6.Write a function that takes customer age and returns the age group(teen,young adult,adult,senior")
def age_group(age):
    if age < 20:
        return 'Teen'
    elif age < 35:
        return 'Young Adult'
    elif age < 60:
        return 'Adult'
    else:
        return 'Senior'

df['Age Group'] = df['Customer Age'].apply(age_group)
print(df['Age Group'].value_counts())

print("7.Use list comprehension to get all orders where net revenue >5000")
